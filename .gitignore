
### `.gitignore`

```gitignore id="1p0a03"
# macOS
.DS_Store

# editor
.vscode/
.idea/

# node
node_modules/
.pnpm-store/
.next/
dist/
coverage/

# python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# environment
.env
.env.local
.env.*.local

# docker / local infra
postgres-data/
redis-data/
minio-data/

# logs
*.log

# playwright auth state
playwright/.auth/

# misc
.turbo/

# local app cache / generated artifacts
apps/api/.cache/
.metrics_tmp/

# local metrics outputs
ingest_response.json
index_response.json
search_response.json
ask_response.json
ingest_times.txt
index_times.txt
search_times.txt
ask_times.txt
chunk_counts.txt
